# ---- Database ----
POSTGRES_USER=medlit
POSTGRES_PASSWORD=medlit
POSTGRES_DB=medlit
# Local dev uses localhost; Docker Compose uses service name 'db'
DATABASE_URL=postgresql+asyncpg://medlit:medlit@localhost:5432/medlit

# ---- Redis ----
# Local dev uses localhost; Docker Compose uses service name 'redis'
REDIS_URL=redis://localhost:6379/0

# ---- App ----
DEBUG=false

# ---- LLM ----
# Required for PICO extraction and evidence synthesis
GEMINI_API_KEY=

# ---- PubMed ----
# Optional — raises rate limit from 3 req/s to 10 req/s
# Register at https://www.ncbi.nlm.nih.gov/account/
NCBI_API_KEY=

# ---- Scheduler ----
# Set to false in tests to prevent background scheduler from starting
SCHEDULER_ENABLED=true

# ---- Notifications (optional) ----
# Slack webhook URL — send notifications on pipeline completion/failure
SLACK_WEBHOOK_URL=
# SMTP settings for email notifications
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_ADDRESS=
NOTIFICATION_EMAIL_TO=

# ---- Dashboard ----
# URL of the FastAPI backend (used by Streamlit)
MEDLIT_API_URL=http://localhost:8000

# ---- Logging ----
# Use 'console' for coloured local dev output; 'json' for production
# (controlled by DEBUG flag — debug=true → console, debug=false → json)
